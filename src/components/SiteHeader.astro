---
import BrandMark from './BrandMark.astro';
import { strings, DEFAULT_LANG } from '../i18n/strings';

const t = strings[DEFAULT_LANG];
---
<header class="site-header">
  <div class="container">
    <div class="row">
      <a class="brand" href="/">
        <span class="brand-icon"><BrandMark /></span>
        <span class="brand-mark" data-i18n="brand">{t.brand}</span>
        <span class="brand-sub" data-i18n="brandSub">{t.brandSub}</span>
      </a>

      <nav class="site-nav" aria-label="Site">
        <a href="/" data-i18n="navHome">{t.navHome}</a>
        <a href="/library" data-i18n="navBrowse">{t.navBrowse}</a>
        <a href="/request" data-i18n="navRequest">{t.navRequest}</a>
      </nav>

      <div
        class="lang-switcher"
        role="group"
        data-i18n-aria-label="langGroupLabel"
        aria-label={t.langGroupLabel}
      >
        {/* Two labels per button: the full word for desktop, a compact one-
            letter form for mobile. CSS picks which is visible. No data-i18n
            here on purpose — the language buttons always show their own name
            in their own language, independent of the active chrome language. */}
        <button type="button" data-lang="he" aria-label="עברית">
          <span class="lang-toggle-full">עברית</span>
          <span class="lang-toggle-short" aria-hidden="true">ע</span>
        </button>
        <button type="button" data-lang="en" aria-label="English">
          <span class="lang-toggle-full">English</span>
          <span class="lang-toggle-short" aria-hidden="true">EN</span>
        </button>
      </div>
    </div>
  </div>
  <div class="editorial-rule"></div>
</header>
