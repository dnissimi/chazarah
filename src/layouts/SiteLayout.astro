---
import '../styles/global.css';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { strings, DEFAULT_LANG, DIR, LANG_STORAGE_KEY } from '../i18n/strings';

interface Props {
  title: string;
}
const { title } = Astro.props;
const lang = DEFAULT_LANG;
const dir = DIR[lang];

// Inline the strings table so the client-side switcher can read it without a fetch.
const stringsJson = JSON.stringify(strings);
---
<!doctype html>
<html lang={lang} dir={dir}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=David+Libre:wght@400;500;700&family=Assistant:wght@300;400;500;600;700&display=swap"
    />

    {/* Apply stored language before paint so dir/lang don't flicker. */}
    <script is:inline define:vars={{ key: LANG_STORAGE_KEY }}>
      try {
        const stored = localStorage.getItem(key);
        if (stored === 'he' || stored === 'en') {
          document.documentElement.lang = stored;
          document.documentElement.dir = stored === 'he' ? 'rtl' : 'ltr';
        }
      } catch (_) {
        /* localStorage unavailable — render in the default Hebrew. */
      }
    </script>
  </head>

  <body>
    <div class="shell">
      <SiteHeader />
      <main class="site-main">
        <slot />
      </main>
      <SiteFooter />
    </div>

    <script is:inline define:vars={{ stringsJson, storageKey: LANG_STORAGE_KEY }}>
      const STRINGS = JSON.parse(stringsJson);

      function currentLang() {
        const stored = localStorage.getItem(storageKey);
        return stored === 'en' ? 'en' : 'he';
      }

      function applyLang(lang) {
        const html = document.documentElement;
        html.lang = lang;
        html.dir = lang === 'he' ? 'rtl' : 'ltr';

        const table = STRINGS[lang] || {};
        const fallback = STRINGS.he;

        document.querySelectorAll('[data-i18n]').forEach((el) => {
          const k = el.getAttribute('data-i18n');
          if (!k) return;
          const value = table[k] ?? fallback[k];
          if (value != null) el.textContent = value;
        });

        document.querySelectorAll('[data-i18n-aria-label]').forEach((el) => {
          const k = el.getAttribute('data-i18n-aria-label');
          if (!k) return;
          const value = table[k] ?? fallback[k];
          if (value != null) el.setAttribute('aria-label', value);
        });

        document.querySelectorAll('[data-i18n-placeholder]').forEach((el) => {
          const k = el.getAttribute('data-i18n-placeholder');
          if (!k) return;
          const value = table[k] ?? fallback[k];
          if (value != null) el.setAttribute('placeholder', value);
        });

        // Bilingual per-page content (e.g. map title/blurb pulled from a YAML
        // entry, not the strings table): values live on the element itself.
        // Fall back to Hebrew when the active-language attribute is absent.
        document.querySelectorAll('[data-i18n-he]').forEach((el) => {
          const value = el.getAttribute('data-i18n-' + lang) ?? el.getAttribute('data-i18n-he');
          if (value != null) el.textContent = value;
        });

        document.querySelectorAll('.lang-switcher button[data-lang]').forEach((btn) => {
          if (btn.getAttribute('data-lang') === lang) {
            btn.classList.add('active');
            btn.setAttribute('aria-pressed', 'true');
          } else {
            btn.classList.remove('active');
            btn.setAttribute('aria-pressed', 'false');
          }
        });
      }

      function setLang(lang) {
        try {
          localStorage.setItem(storageKey, lang);
        } catch (_) {
          /* swallow — switcher still works for the current page */
        }
        applyLang(lang);
      }

      document.querySelectorAll('.lang-switcher button[data-lang]').forEach((btn) => {
        btn.addEventListener('click', () => {
          const lang = btn.getAttribute('data-lang');
          if (lang === 'he' || lang === 'en') setLang(lang);
        });
      });

      applyLang(currentLang());
    </script>
  </body>
</html>
