---
import '../styles/global.css';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { resolved, DIR, type Lang } from '../i18n/strings';
import { alternates } from '../i18n/urls';

interface Props {
  /** Page language. Determines <html lang>/dir and which strings render. Each
      route passes this explicitly (he at root, en under /en) — the page renders
      its language SERVER-SIDE so crawlers see real content, not a JS swap. */
  lang: Lang;
  /** The full <title>. */
  title: string;
  /** <meta name="description"> — per page, per language. */
  description: string;
  /** Language-neutral path of this logical page (e.g. '/', '/library',
      '/map/talmud/megillah/26'). Drives canonical + hreflang + the language
      switcher's destination URLs. */
  canonicalPath: string;
  /** og:type — 'website' for chrome, 'article' for map/info pages. */
  ogType?: string;
  /** Optional JSON-LD object (or array of objects) rendered as ld+json. */
  jsonLd?: unknown;
}

const {
  lang,
  title,
  description,
  canonicalPath,
  ogType = 'website',
  jsonLd,
} = Astro.props;

const dir = DIR[lang];
const t = resolved(lang);
const alt = alternates(canonicalPath, lang);
const ogLocale = lang === 'he' ? 'he_IL' : 'en_US';
const ogLocaleAlt = lang === 'he' ? 'en_US' : 'he_IL';
const jsonLdList = jsonLd == null ? [] : Array.isArray(jsonLd) ? jsonLd : [jsonLd];

// Relative path to the English counterpart of this page (same rule the language
// switcher uses): '/en' + path, with '/' collapsing to bare '/en'. Used by the
// "available in English" suggestion banner below.
const enPath = '/en' + (canonicalPath === '/' ? '' : canonicalPath);

// `?embed=1` strips site chrome (header/footer) so the slot can fill an iframe
// cleanly — used by the gemara-map "report a correction" modal (see
// docs/specs/map-wiring.md refinement 2026-05-30). Detected client-side in the
// pre-paint script below because these pages are mostly prerendered, so a
// server-side Astro.url check would be empty at build time.
---
<!doctype html>
<html lang={lang} dir={dir}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <link rel="canonical" href={alt.canonical} />
    <link rel="alternate" hreflang="he" href={alt.he} />
    <link rel="alternate" hreflang="en" href={alt.en} />
    <link rel="alternate" hreflang="x-default" href={alt.xDefault} />

    {/* Open Graph + Twitter — for link previews when a map is shared. */}
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={t.brand} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={alt.canonical} />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:locale:alternate" content={ogLocaleAlt} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=David+Libre:wght@400;500;700&family=Assistant:wght@300;400;500;600;700&display=swap"
    />

    {jsonLdList.map((obj) => (
      <script type="application/ld+json" is:inline set:html={JSON.stringify(obj)} />
    ))}

    {/* Embed mode (set by the pre-paint script when `?embed=1`): page is hosted
        inside an iframe (e.g. the gemara-map feedback modal) — hide outer chrome
        so the slot fills the iframe cleanly. */}
    <style is:global>
      html[data-embed="1"] .site-header,
      html[data-embed="1"] .site-footer{display:none}
      html[data-embed="1"] .shell{padding:0;min-height:auto}
      html[data-embed="1"] .site-main{padding-block:0;min-height:auto}
      html[data-embed="1"] .container{padding-block:1rem}
    </style>

    {/* Page language is fixed server-side by the URL (he at root, en under
        /en) — there is no client-side language swap. The only thing this
        pre-paint script does is flag `?embed=1` so the chrome-hiding CSS above
        applies before first paint. */}
    <script is:inline>
      try {
        if (new URLSearchParams(location.search).get('embed') === '1') {
          document.documentElement.dataset.embed = '1';
        }
      } catch (_) {
        /* URL unavailable — render with chrome. */
      }
    </script>
  </head>

  <body>
    <div class="shell">
      {/* Locale suggestion: on the Hebrew pages, gently offer English to
          visitors whose browser isn't set to Hebrew. A nudge, NOT an auto
          redirect — Hebrew stays canonical/x-default and the page stays static
          (per the SEO plan's "switcher links only" decision). Hidden until the
          inline script below decides to show it; dismissal/choice is remembered
          in localStorage so it only ever appears once. English-only audience,
          so its text + arrow read LTR even on the RTL page. */}
      {lang === 'he' && (
        <Fragment>
          <div class="lang-suggest" id="lang-suggest" dir="ltr" hidden>
            <div class="container">
              <span class="lang-suggest-text">This site is also available in English.</span>
              <a class="lang-suggest-cta" href={enPath} data-lang-suggest-go>View in English →</a>
              <button
                class="lang-suggest-close"
                type="button"
                aria-label="Dismiss"
                data-lang-suggest-close
              >×</button>
            </div>
          </div>
          <script is:inline>
            (function () {
              try {
                if (document.documentElement.dataset.embed === '1') return;
                var K = 'chazarah.langSuggest.v1';
                if (localStorage.getItem(K)) return;
                var primary = (navigator.language || (navigator.languages || [])[0] || '').toLowerCase();
                // Skip Hebrew browsers (modern 'he', legacy 'iw'); nudge everyone else.
                if (/^(he|iw)\b/.test(primary)) return;
                var el = document.getElementById('lang-suggest');
                if (!el) return;
                el.hidden = false;
                var remember = function () { try { localStorage.setItem(K, '1'); } catch (_) {} };
                el.querySelector('[data-lang-suggest-close]').addEventListener('click', function () {
                  remember();
                  el.hidden = true;
                });
                // Clicking through to English also counts as handled — don't nag again.
                el.querySelector('[data-lang-suggest-go]').addEventListener('click', remember);
              } catch (_) {
                /* storage/navigator unavailable — just don't show the banner. */
              }
            })();
          </script>
        </Fragment>
      )}
      <SiteHeader lang={lang} canonicalPath={canonicalPath} />
      <main class="site-main">
        <slot />
      </main>
      <SiteFooter lang={lang} />
    </div>
  </body>
</html>
