---
import SiteLayout from '../layouts/SiteLayout.astro';
import { strings, DEFAULT_LANG } from '../i18n/strings';

const t = strings[DEFAULT_LANG];
---
<SiteLayout title="חזרה — Chazarah">
  <section class="home-hero container">
    <div class="wordmark" data-i18n="brand">{t.brand}</div>
    <h1 class="tagline" data-i18n="homeTagline">{t.homeTagline}</h1>
    <p class="intro" data-i18n="homeIntro">{t.homeIntro}</p>
  </section>
</SiteLayout>
