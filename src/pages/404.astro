---
import SiteLayout from '../layouts/SiteLayout.astro';
import { strings, DEFAULT_LANG } from '../i18n/strings';

const t = strings[DEFAULT_LANG];
---
<SiteLayout title="404 — חזרה">
  <section class="notfound container narrow">
    <div class="kicker" data-i18n="notFoundKicker">{t.notFoundKicker}</div>
    <h1 data-i18n="notFoundTitle">{t.notFoundTitle}</h1>
    <p data-i18n="notFoundBody">{t.notFoundBody}</p>
    <a class="home-link" href="/" data-i18n="notFoundHome">{t.notFoundHome}</a>
  </section>
</SiteLayout>
